        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.access) {",
                  "        pm.collectionVariables.set('admin_token', response.access);",
                  "        pm.test('Admin login successful', function () {",
                  "            pm.response.to.have.status(200);",
                  "        });",
                  "    }",
                  "} else {",
                  "    pm.test('Admin login failed', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login", ""]
            }
          },
          "response": []
        },
        {
          "name": "Generate Test JWT Token",
          "event": [
            {
              "listen": "pre-request",
              "script": {
                "exec": [
                  "// Generate a test JWT token for Sovtes",
                  "const CryptoJS = require('crypto-js');",
                  "",
                  "// JWT Header",
                  "const header = {",
                  "    \"alg\": \"RS512\",",
                  "    \"typ\": \"JWT\"",
                  "};",
                  "",
                  "// JWT Payload",
                  "const payload = {",
                  "    \"sub\": \"test_sovtes_user_001\",",
                  "    \"client_id\": \"sovtes_test_client\",",
                  "    \"client_name\": \"Sovtes Test Company\",",
                  "    \"email\": \"test@sovtes.com\",",
                  "    \"first_name\": \"Test\",",
                  "    \"last_name\": \"User\",",
                  "    \"subscription_plan_id\": 1,",
                  "    \"subscription_plan_name\": \"Basic Plan\",",
                  "    \"iat\": Math.floor(Date.now() / 1000),",
                  "    \"exp\": Math.floor(Date.now() / 1000) + 3600,",
                  "    \"iss\": \"sovtes.com\",",
                  "    \"aud\": \"malog.com\"",
                  "};",
                  "",
                  "// Base64URL encode",
                  "function base64urlEncode(str) {",
                  "    return CryptoJS.enc.Base64.stringify(CryptoJS.enc.Utf8.parse(str))",
                  "        .replace(/\\+/g, '-')",
                  "        .replace(/\\//g, '_')",
                  "        .replace(/=/g, '');",
                  "}",
                  "",
                  "const encodedHeader = base64urlEncode(JSON.stringify(header));",
                  "const encodedPayload = base64urlEncode(JSON.stringify(payload));",
                  "",
                  "// For testing without signature verification",
                  "const testToken = encodedHeader + '.' + encodedPayload + '.test_signature';",
                  "pm.collectionVariables.set('test_token', testToken);",
                  "",
                  "console.log('Generated test token:', testToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health/",
              "host": ["{{base_url}}"],
              "path": ["api", "health", ""]
            },
            "description": "This is a dummy request to generate the test token in pre-request script"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sovtes JWT Authentication",
      "item": [
        {
          "name": "Login with Sovtes JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has required fields', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('access');",
                  "    pm.expect(response).to.have.property('refresh');",
                  "    pm.expect(response).to.have.property('user');",
                  "    pm.expect(response).to.have.property('client');",
                  "    pm.expect(response).to.have.property('subscription');",
                  "});",
                  "",
                  "pm.test('User is created correctly', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.user.username).to.include('sovtes_');",
                  "    pm.expect(response.user.email).to.eql('test@sovtes.com');",
                  "});",
                  "",
                  "pm.test('Client is created correctly', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.client.name).to.eql('Sovtes Test Company');",
                  "    pm.expect(response.client.slug).to.include('sovtes-test-company');",
                  "});",
                  "",
                  "pm.test('Subscription info is present', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.subscription).to.have.property('plan');",
                  "    pm.expect(response.subscription).to.have.property('status');",
                  "});",
                  "",
                  "// Store user ID for management tests",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('sovtes_user_id', response.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
