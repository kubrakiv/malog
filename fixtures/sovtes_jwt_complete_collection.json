        {
          "name": "Verify Sovtes JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Token is valid', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('valid', true);",
                  "    pm.expect(response).to.have.property('claims');",
                  "});",
                  "",
                  "pm.test('Claims are extracted correctly', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.claims).to.have.property('sub');",
                  "    pm.expect(response.claims).to.have.property('client_id');",
                  "    pm.expect(response.claims).to.have.property('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
