# Normalize line endings and ensure text files are merged as text

# Auto-detect text files and perform LF normalization
* text=auto

# Force LF for common project text files
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts must use LF or the shebang breaks on Linux
*.sh text eol=lf

# Specifically ensure requirements files are treated as text
requirements*.txt text eol=lf

# Do not normalize images/binaries
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.ico -text
*.pdf -text
*.sqlite3 -text